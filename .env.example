# ============================================================
# Arquivo: .env.example
# ------------------------------------------------------------
# Este arquivo mostra quais variáveis de ambiente o projeto
# precisa para funcionar.
#
# Para rodar o projeto, copie este arquivo, renomeie a cópia para
# .env e preencha os valores reais.
#
# Atenção:
# Nunca coloque a chave real da API neste arquivo.
# A chave real deve ficar apenas no arquivo .env.
# ============================================================

GEMMA_BASE_URL=https://llm.liaufms.org/v1/gemma-3-12b-it
GEMMA_API_KEY=COLOQUE_A_CHAVE_AQUI
GEMMA_MODEL=google/gemma-3-12b-it